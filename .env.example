# Copia este archivo a .env y rellena. .env nunca se commitea.

# Binance Spot API. Para BACKTEST no se necesitan — solo descarga pública.
# Para LIVE/PAPER (más adelante): crea keys con permiso solo de Spot Trading,
# NUNCA de Withdrawals. Restringe por IP cuando despliegues.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Si usas testnet de Binance Spot (recomendado antes de live real)
BINANCE_TESTNET=false

# Copia este archivo a .env y rellena. .env nunca se commitea.

# =============================================================================
# Bot Binance 12 — variables de entorno
# =============================================================================

# --- Binance Spot ---
# Sin estas, el bot arranca en MODO PAPER (no envía órdenes reales).
# Para LIVE: crea keys con permiso de Spot Trading ÚNICAMENTE.
# NUNCA marques "Enable Withdrawals". Restringe por IP en Railway.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Forzar paper trading (recomendado al menos las primeras semanas).
# Si pones FORCE_PAPER=true el bot ignora las API keys aunque existan.
FORCE_PAPER=true

# --- Dashboard / healthcheck ---
# Auth básica para el endpoint /status (no expongas el bot sin esto).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=cambiame-en-railway

# --- Base de datos ---
# En Railway debe apuntar al volumen montado (ej: /app/data/bot.db).
DATABASE_PATH=./data/bot.db

# --- Logging ---
LOG_LEVEL=INFO
